// DATABASE PROMO
const promoCodes = {

  "YAZZBET": 500000,

  "FREE100": 100000,

  "WELCOME": 250000,

  "CASEBET": 750000


};

// CLAIM PROMO
function claimPromo(){

  const promo =
  document
  .getElementById("promoInput")
  .value
  .toUpperCase();

  // cek promo ada atau tidak
  if(!promoCodes[promo]){

    alert("Promo code salah!");

    return;
  }

  // cek sudah dipakai
  const alreadyUsed =
  localStorage.getItem(
    "promo_" + promo
  );

  if(alreadyUsed){

    alert(
      "Promo sudah digunakan!"
    );

    return;
  }

  // hadiah promo
  const reward =
  promoCodes[promo];

  balance += reward;

  balanceText.innerHTML =
  balance;

  // simpan balance
  localStorage.setItem(
    "rouletteBalance",
    balance
  );

  // tandai sudah claim
  localStorage.setItem(
    "promo_" + promo,
    "used"
  );

  alert(
    "Promo berhasil! +" + reward
  );

  closePromo();
}

// UPDATE UI
function updateLevelUI(){

  const needXP =
  level * 100;

  document.getElementById(
    "levelText"
  ).innerHTML = level;

  document.getElementById(
    "xpText"
  ).innerHTML = xp;

  document.getElementById(
    "xpNeed"
  ).innerHTML = needXP;

  const percent =
  (xp / needXP) * 100;

  document.getElementById(
    "xpFill"
  ).style.width =
  percent + "%";

  // SAVE
  localStorage.setItem(
    "rouletteLevel",
    level
  );

  localStorage.setItem(
    "rouletteXP",
    xp
  );
}

// ADD XP
function addXP(amount){

  xp += amount;

  let needXP =
  level * 100;

  // LEVEL UP
  while(xp >= needXP){

    xp -= needXP;

    level++;

    needXP =
    level * 100;

    alert(
      "LEVEL UP! LEVEL " + level
    );
  }

  // SAVE
  localStorage.setItem(
    "rouletteXP",
    xp
  );

  localStorage.setItem(
    "rouletteLevel",
    level
  );

  updateLevelUI();
}

