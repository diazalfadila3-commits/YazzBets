const betInput =
document.getElementById("betAmount");

// HALF
function halfBet(){

  let value =
  Number(betInput.value);

  value =
  Math.floor(value / 2);

  if(value < 1){
    value = 1;
  }

  betInput.value = value;
}

// DOUBLE
function doubleBet(){

  let value =
  Number(betInput.value);

  value *= 2;

  if(value > balance){
    value = balance;
  }

  betInput.value = value;
}

// MAX
function maxBet(){

  betInput.value = balance;
}

