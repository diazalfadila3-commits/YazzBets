// SEND TIP
function sendTip(){

  const target =
  document
  .getElementById("tipName")
  .value
  .trim();

  const amount =
  Number(
    document
    .getElementById("tipAmount")
    .value
  );

  // validasi
  if(target === ""){

    alert("Masukkan nama!");

    return;
  }

  if(amount <= 0){

    alert("Jumlah tidak valid!");

    return;
  }

  if(amount > balance){

    alert("Balance tidak cukup!");

    return;
  }

  // player tidak ada
  if(!players[target]){

    alert("Player tidak ditemukan!");

    return;
  }

  // tidak bisa tip diri sendiri
  if(target === username){

    alert("Tidak bisa tip diri sendiri!");

    return;
  }

  // kurangi balance sendiri
  balance -= amount;

  // tambah balance target
  players[target].balance += amount;

  // save balance sendiri
  balanceText.innerHTML =
  balance;

  localStorage.setItem(
    "rouletteBalance",
    balance
  );

  // save player db
  localStorage.setItem(
    "roulettePlayers",
    JSON.stringify(players)
  );

  alert(
    "Berhasil tip $" +
    amount +
    " ke " +
    target
  );

  closeTip();
}




